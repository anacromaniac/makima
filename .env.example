# ============================================
# Makima - Investment Tracker Backend
# Configuration File (Example)
# ============================================
# Copy this file to .env and fill in your values.
# Do not commit .env to version control.

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://makima:your-postgres-password-change-this@localhost:5432/makima

# Maximum pool size for sqlx connections
# Keep low on Raspberry Pi to conserve RAM (default: 5)
DATABASE_POOL_MAX_SIZE=5

# Password for postgres database
POSTGRES_PASSWORD=your-postgres-password-change-this

# ============================================
# JWT Configuration
# ============================================
# Secret for signing JWT tokens (HS256)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-this-in-production

# Access token expiration (default: 1h)
JWT_ACCESS_TOKEN_EXPIRY=1h

# Refresh token expiration (default: 7d)
JWT_REFRESH_TOKEN_EXPIRY=7d

# ============================================
# External APIs
# ============================================
# Base URL for Yahoo Finance API
YAHOO_FINANCE_BASE_URL=https://query1.finance.yahoo.com

# OpenFIGI API key (optional - free tier available)
OPENFIGI_API_KEY=

# Milliseconds to wait between Yahoo Finance requests (default: 1500ms)
# Helps avoid rate limiting
YAHOO_REQUEST_DELAY_MS=1500

# Years of price history to fetch on first import (default: 5)
BACKFILL_YEARS=5

# ============================================
# Server Configuration
# ============================================
# Listen host (default: 0.0.0.0 - all interfaces)
SERVER_HOST=0.0.0.0

# Listen port (default: 3000)
SERVER_PORT=3000

# CORS allowed origins (comma-separated)
# Example: http://localhost:3000,https://app.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ============================================
# Scheduled Jobs
# ============================================
# Cron expression for daily price update job
# Default: 0 0 22 * * (every day at 22:00)
PRICE_UPDATE_CRON="0 0 22 * *"

# ============================================
# Logging Configuration
# ============================================
# Log level: trace, debug, info, warn, error
# Format: api=info (crate=loglevel) or just use 'info' for everything
RUST_LOG=info
